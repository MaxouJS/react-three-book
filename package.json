{
  "name": "@objectifthunes/react-three-book",
  "version": "0.1.0",
  "description": "React Three Fiber wrapper for @objectifthunes/three-book",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts"
  },
  "peerDependencies": {
    "@objectifthunes/three-book": ">=0.1.2",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@objectifthunes/three-book": "^0.1.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
